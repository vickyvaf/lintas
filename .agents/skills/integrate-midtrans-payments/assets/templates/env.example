# Midtrans environment template for merchant projects.
#
# Pick only the variables your integration uses. The skill's project-adaptation
# checklist wires these through (in order): example env file, typed validation,
# deployment secret manager, CI drift tests, operator handoff docs.
#
# Sandbox vs production:
#   - Sandbox server keys start with "SB-Mid-server-".
#   - Production server keys start with "Mid-server-".
#   - Sandbox BI-SNAP host: merchants.sbx.midtrans.com
#   - Production BI-SNAP host: merchants.midtrans.com
#
# Never commit real values. Use a secret manager for production.

# -------- Snap / Core API --------
# Backend-only. Used in Authorization: Basic base64(serverKey + ":").
MIDTRANS_SERVER_KEY=SB-Mid-server-REPLACE_ME

# Browser-side. Used by Snap JS to initialize the Snap UI.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-REPLACE_ME

# Toggle that selects sandbox vs production endpoints.
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# -------- BI-SNAP (custom QRIS / VA / Direct Debit / GoPay tokenization) --------
BISNAP_CLIENT_ID=REPLACE_ME
BISNAP_CLIENT_SECRET=REPLACE_ME
BISNAP_PARTNER_ID=REPLACE_ME
BISNAP_CHANNEL_ID=REPLACE_5_DIGITS
BISNAP_MERCHANT_ID=REPLACE_ME

# Asymmetric key used for the access-token request signature.
# Accepts raw PEM, \n-escaped PEM, or base64-encoded PEM.
BISNAP_PRIVATE_KEY=base64-or-pem-private-key

# Midtrans public key used to verify incoming BI-SNAP notification signatures.
# BISNAP_PUBLIC_KEY is preferred; BISNAP_MIDTRANS_PUBLIC_KEY is a legacy alias.
BISNAP_PUBLIC_KEY=base64-or-pem-public-key
BISNAP_MIDTRANS_PUBLIC_KEY=base64-or-pem-public-key

# Virtual Account partner service id. Required to be 1-8 digits or an
# 8-character left-space-padded value (see scripts/format_partner_service_id.sh).
BISNAP_PARTNER_SERVICE_ID=12345

# Sandbox vs production switch.
BISNAP_IS_PRODUCTION=false

# -------- GoPay tokenization (separate handle vs id) --------
# Used in get-auth-code and binding. Often a UUID-like value provided by
# Midtrans during onboarding. Distinct from BISNAP_GOPAY_MERCHANT_ID below.
BISNAP_GOPAY_MERCHANT_HANDLE=REPLACE_ME

# Used in Direct Debit charges and QRIS as the standard merchantId.
BISNAP_GOPAY_MERCHANT_ID=REPLACE_ME

# -------- Feature flags --------
# Keep GoPay tokenization and GoPayLater disabled until merchant activation
# and sandbox smoke verification both pass.
PAYMENT_GOPAY_ENABLED=false
PAYMENT_GOPAY_TOKENIZATION_ENABLED=false
PAYMENT_GOPAYLATER_ENABLED=false

# -------- Recurring / subscriptions --------
# Set when the merchant separates Recurring Notification URL from the
# one-time Payment Notification URL on the dashboard. Mount a distinct
# handler at this path so recurring webhooks don't land on the one-time
# route.
PAYMENT_RECURRING_NOTIFICATION_PATH=/api/payment/webhook/recurring

# -------- Per-transaction notification routing --------
# Optional overrides for token creation. Both must be public HTTPS in
# production and the merchant handlers must remain idempotent across
# all listed URLs. Leave unset to use the dashboard Payment Notification
# URL unchanged.
PAYMENT_OVERRIDE_NOTIFICATION_URL=
PAYMENT_APPEND_NOTIFICATION_URLS=

# -------- Refund defaults --------
# Used when generating deterministic refund_key / partnerRefundNo
# values. Keep as a stable per-merchant prefix; the order id and an
# attempt counter are appended at refund time.
PAYMENT_REFUND_KEY_PREFIX=merchant-refund

# -------- Mobile WebView / app links --------
# Custom URL scheme registered in Info.plist (iOS) and intent-filter
# (Android). Use only after real-device wallet return has been tested.
PAYMENT_MOBILE_DEEPLINK_SCHEME=merchantapp
